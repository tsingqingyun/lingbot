{
  "train_micro_batch_size_per_gpu": 1,
  "gradient_accumulation_steps": 8,
  "gradient_clipping": 1.0,
  "bf16": {
    "enabled": true
  },
  "fp16": {
    "enabled": false
  },
  "zero_optimization": {
    "stage": 2,
    "contiguous_gradients": true,
    "overlap_comm": true,
    "reduce_scatter": true,
    "allgather_partitions": true,
    "allgather_bucket_size": 50000000,
    "reduce_bucket_size": 50000000,
    "offload_optimizer": {
      "device": "cpu",
      "pin_memory": true
    }
  }
}
